# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/silent-emergency-shield

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Public URL for Telegram webhook (use ngrok URL when testing locally)
# e.g. https://abc123.ngrok.io
BACKEND_PUBLIC_URL=https://your-public-url-here

# Fast2SMS — SMS alert delivery (India only, 10-digit numbers)
# Sign up free at https://www.fast2sms.com/ → Dev API → copy your API key
# Leave blank to disable SMS alerts (Telegram will still work independently)
FAST2SMS_API_KEY=your-fast2sms-api-key-here
